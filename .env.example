APP_ENV=development
LOG_LEVEL=INFO
AWS_REGION=us-east-1
IOT_ENDPOINT=your-endpoint-ats.iot.us-east-1.amazonaws.com
IOT_CLIENT_ID=device-simulator-001
IOT_THING_NAME=device-simulator-001
IOT_TOPIC=devices/device-simulator-001/telemetry
IOT_CERT_PATH=certs/device.pem.crt
IOT_KEY_PATH=certs/private.pem.key
IOT_CA_PATH=certs/AmazonRootCA1.pem
# Classic shadow: leave empty. Named shadow: set to the shadow name (not the full topic).
IOT_SHADOW_NAME=
FIRMWARE_VERSION=1.0.0
PUBLISH_INTERVAL_SECONDS=5
# HTTPS JSON polled in the background; merges with shadow (shadow still wins on subsequent deltas).
# Example body: {"config_version":3,"publish_interval_seconds":15,"telemetry_topic":"devices/my-thing/telemetry","sensors":{"cpu_temp_c":true,"ambient_temp_c":true},"feature_flags":{"advanced_metrics":true}}
REMOTE_CONFIG_URL=
REMOTE_CONFIG_POLL_SECONDS=300
REMOTE_CONFIG_REQUEST_TIMEOUT_SECONDS=10
# Optional: comma-separated hostnames (lowercase). When set, fetches are limited to these hosts.
REMOTE_CONFIG_ALLOWED_HOSTS=
# Optional: Authorization bearer for API Gateway–backed config (never commit real tokens).
REMOTE_CONFIG_BEARER_TOKEN=
# Local dev only: allow http:// URLs (e.g. http://127.0.0.1:8080/config.json).
REMOTE_CONFIG_ALLOW_INSECURE_HTTP=false
# AWS IoT Jobs (device MQTT): subscribe to notify-next / start-next, run allowlisted job documents, report status.
# Set to false to disable the subscriber while still publishing telemetry.
IOT_JOBS_ENABLED=true
# Optional: non-reserved MQTT topic for small post-job audit records (thing_name, job_id, status, operation, timestamps).
IOT_JOBS_AUDIT_TOPIC=
