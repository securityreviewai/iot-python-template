APP_ENV=development
LOG_LEVEL=INFO
AWS_REGION=us-east-1
IOT_ENDPOINT=your-endpoint-ats.iot.us-east-1.amazonaws.com
IOT_CLIENT_ID=device-simulator-001
IOT_THING_NAME=device-simulator-001
IOT_TOPIC=devices/device-simulator-001/telemetry
IOT_CERT_PATH=certs/device.pem.crt
IOT_KEY_PATH=certs/private.pem.key
IOT_CA_PATH=certs/AmazonRootCA1.pem
PUBLISH_INTERVAL_SECONDS=5
# Device Shadow: leave IOT_SHADOW_NAME empty for the classic shadow, or set a name for a named shadow.
IOT_SHADOW_NAME=
IOT_SHADOW_ENABLED=true
# Seconds between shadow reported updates (last telemetry time, etc.). Set to 0 to only report on desired/delta.
IOT_SHADOW_REPORT_INTERVAL_SECONDS=60
# HTTPS remote config (API Gateway, S3 website, etc.). Leave empty to disable.
# URL may include {thing_name} or {thing} placeholders (URL-encoded when needed).
REMOTE_CONFIG_URL=
REMOTE_CONFIG_POLL_SECONDS=300
REMOTE_CONFIG_TIMEOUT_SECONDS=15
# Optional full Authorization header value, e.g. "Bearer <token>"
REMOTE_CONFIG_AUTH_HEADER=
# AWS IoT Jobs (MQTT). Disable if the device policy has no jobs permissions.
IOT_JOBS_ENABLED=true
